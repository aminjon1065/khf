# Staging environment template (ТЗ §16.1, §18.1 UAT).
# Copy to `.env` on the staging host (or use `php artisan env:encrypt --env=staging`).
# Generate secrets on the server — never commit real values.

APP_NAME=КҲФ
APP_ENV=staging
APP_KEY=
APP_DEBUG=false
APP_URL=https://staging.khf.tj
TRUSTED_PROXIES=none

APP_LOCALE=tj
APP_FALLBACK_LOCALE=tj
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=14
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=khf_staging
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MATOMO_URL=
MATOMO_SITE_ID=
MATOMO_GOAL_APPEAL=
MATOMO_GOAL_TOURIST_GROUP=
MATOMO_GOAL_SUBSCRIPTION=

SOCIAL_TELEGRAM_URL=
SOCIAL_FACEBOOK_URL=
SOCIAL_INSTAGRAM_URL=
SOCIAL_YOUTUBE_URL=
SOCIAL_X_URL=

VAPID_SUBJECT="${APP_URL}"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

HEALTH_CHECK_TOKEN=
HEALTH_FAILED_JOBS_THRESHOLD=10
HEALTH_PENDING_JOBS_THRESHOLD=1000
HEALTH_SCHEDULER_MAX_AGE=180
