# Production environment template (ТЗ §16.1).
# Copy to `.env` on the shared host (or use `php artisan env:encrypt --env=production`).
# Run `php artisan deploy:env-check` before every deploy.

APP_NAME=КҲФ
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://khf.tj

APP_LOCALE=tj
APP_FALLBACK_LOCALE=tj
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Daily rotation with 30-day retention — a single unbounded log file can fill the disk on a 24/7
# host and take the alert path down with it (ТЗ §16.3).
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=30
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Public media (images/documents surfaced on the portal) live on the public disk. Uploads are
# restricted to an image/document allowlist and SVG/HTML are rejected (StoreMediaRequest), so this
# stays XSS-safe (ТЗ §12.4).
MEDIA_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MATOMO_URL=
MATOMO_SITE_ID=
MATOMO_GOAL_APPEAL=
MATOMO_GOAL_TOURIST_GROUP=
MATOMO_GOAL_SUBSCRIPTION=

SOCIAL_TELEGRAM_URL=
SOCIAL_FACEBOOK_URL=
SOCIAL_INSTAGRAM_URL=
SOCIAL_YOUTUBE_URL=
SOCIAL_X_URL=

VAPID_SUBJECT="${APP_URL}"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

HEALTH_CHECK_TOKEN=
HEALTH_FAILED_JOBS_THRESHOLD=10
