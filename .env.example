APP_NAME=КҲФ
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://khf.test

APP_LOCALE=tj
APP_FALLBACK_LOCALE=tj
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=khf
DB_USERNAME=root
DB_PASSWORD=

# Shared-hosting friendly drivers (no Redis daemon). See plan.md D-10.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Corporate SMTP of the Committee (ТЗ §10.8). Use real credentials per environment.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional S3-compatible object storage (e.g. MinIO) on Committee infrastructure (ТЗ §10.7).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Matomo Analytics
MATOMO_URL=
MATOMO_SITE_ID=
MATOMO_GOAL_APPEAL=
MATOMO_GOAL_TOURIST_GROUP=
MATOMO_GOAL_SUBSCRIPTION=

# Official social profiles (footer links only — leave blank to hide)
SOCIAL_TELEGRAM_URL=
SOCIAL_FACEBOOK_URL=
SOCIAL_INSTAGRAM_URL=
SOCIAL_YOUTUBE_URL=
SOCIAL_X_URL=

# Web Push (VAPID) — generate per environment: `php artisan webpush:vapid`
# Safari requires a valid https:// or mailto: subject. Keys must not change after go-live.
VAPID_SUBJECT="${APP_URL}"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Monitoring — optional token for detailed GET /health diagnostics (§16.3)
HEALTH_CHECK_TOKEN=
HEALTH_FAILED_JOBS_THRESHOLD=10
