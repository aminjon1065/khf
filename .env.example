APP_NAME=КҲФ
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://khf.test

# Must match the URL in your browser (Herd: https://khf.test — without :8443).
# A mismatched APP_URL causes CORS/CSP errors loading /build assets locally.

# CMS two-factor auth is required in production. Disabled when APP_ENV=local.
# Set REQUIRE_TWO_FACTOR=true to test 2FA flows locally.
# REQUIRE_TWO_FACTOR=false

APP_LOCALE=tj
APP_FALLBACK_LOCALE=tj
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=khf
DB_USERNAME=root
DB_PASSWORD=

# Shared-hosting friendly drivers (no Redis daemon). See plan.md D-10.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Local HTTP: leave false/unset. Production HTTPS: true (config/session.php default).
# SESSION_SECURE_COOKIE=true

# Behind shared-hosting TLS / reverse proxy. Use * only when the edge proxy is trusted.
# TRUSTED_PROXIES=*
# TRUSTED_PROXIES=10.0.0.1,10.0.0.2

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Corporate SMTP of the Committee (ТЗ §10.8). Use real credentials per environment.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional S3-compatible object storage (e.g. MinIO) on Committee infrastructure (ТЗ §10.7).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Matomo Analytics
MATOMO_URL=
MATOMO_SITE_ID=
MATOMO_GOAL_APPEAL=
MATOMO_GOAL_TOURIST_GROUP=
MATOMO_GOAL_SUBSCRIPTION=

# MapLibre raster tiles (ТЗ §10.8 — prefer own OSM-compatible tile server in production)
MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_TILE_ATTRIBUTION="© OpenStreetMap"
MAP_TILE_SIZE=256
MAP_GLYPHS_URL=https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf

PRESIDENT_URL=https://president.tj
PRESIDENT_PHOTO=/images/president.webp

# Official social profiles (footer links only — leave blank to hide)
SOCIAL_TELEGRAM_URL=
SOCIAL_FACEBOOK_URL=
SOCIAL_INSTAGRAM_URL=
SOCIAL_YOUTUBE_URL=
SOCIAL_X_URL=

# Footer useful-resource links and hotline (CMS globals fallback)
FOOTER_GOVERNMENT_URL=https://government.tj
FOOTER_EGOV_URL=https://egov.tj
FOOTER_HOTLINE=112
# FOOTER_COPYRIGHT=

# Default SEO meta when a page does not define its own
# SEO_DEFAULT_TITLE=
# SEO_DEFAULT_DESCRIPTION=
SEO_DEFAULT_IMAGE=/images/emblem-tj.webp

# Published content cache (Stache-like) — warm after deploy: php artisan cms:cache-warm
CMS_CONTENT_CACHE=true
CMS_CONTENT_CACHE_TTL=3600

# Web Push (VAPID) — generate per environment: `php artisan webpush:vapid`
# Safari requires a valid https:// or mailto: subject. Keys must not change after go-live.
VAPID_SUBJECT="${APP_URL}"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Monitoring — optional token for detailed GET /health diagnostics (§16.3)
HEALTH_CHECK_TOKEN=
HEALTH_FAILED_JOBS_THRESHOLD=10
